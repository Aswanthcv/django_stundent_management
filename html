<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Student Management System</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    background: linear-gradient(135deg,#0f172a,#1e293b);
    color:white;
    min-height:100vh;
}

.hero{
    text-align:center;
    padding:80px 20px;
}

.hero h1{
    font-size:4rem;
    font-weight:bold;
}

.hero p{
    font-size:1.2rem;
    color:#cbd5e1;
}

.card{
    background:rgba(255,255,255,0.08);
    backdrop-filter:blur(10px);
    border:none;
    border-radius:20px;
    color:white;
}

.card:hover{
    transform:translateY(-5px);
    transition:.3s;
}

.btn-custom{
    background:#38bdf8;
    color:white;
    border:none;
}

.btn-custom:hover{
    background:#0ea5e9;
}

.student-table{
    background:white;
    color:black;
    border-radius:15px;
    overflow:hidden;
}

.section-title{
    margin-bottom:20px;
    font-weight:bold;
}
</style>
</head>

<body>

<div class="container">

    <!-- Hero Section -->
    <div class="hero">
        <h1>🎓 Student Management System</h1>
        <p>Manage Students Easily with Django</p>
    </div>

    <!-- Add Student -->
    <div class="card p-4 mb-5">
        <h3 class="section-title">Add Student</h3>

        <form method="POST">
            {% csrf_token %}

            <div class="row">

                <div class="col-md-4 mb-3">
                    <input
                    type="text"
                    name="name"
                    class="form-control"
                    placeholder="Student Name">
                </div>

                <div class="col-md-4 mb-3">
                    <input
                    type="email"
                    name="email"
                    class="form-control"
                    placeholder="Email">
                </div>

                <div class="col-md-4 mb-3">
                    <input
                    type="text"
                    name="course"
                    class="form-control"
                    placeholder="Course">
                </div>

            </div>

            <button class="btn btn-custom">
                Add Student
            </button>

        </form>
    </div>

    <!-- Student List -->
    <div class="card p-4">

        <h3 class="section-title">
            Student Records
        </h3>

        <div class="student-table">

            <table class="table table-striped table-hover mb-0">

                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Course</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>

                    {% for student in students %}

                    <tr>
                        <td>{{ student.id }}</td>
                        <td>{{ student.name }}</td>
                        <td>{{ student.email }}</td>
                        <td>{{ student.course }}</td>

                        <td>

                            <a href="{% url 'update_student' student.id %}"
                               class="btn btn-warning btn-sm">
                                Update
                            </a>

                            <a href="{% url 'delete_student' student.id %}"
                               class="btn btn-danger btn-sm">
                                Delete
                            </a>

                        </td>

                    </tr>

                    {% endfor %}

                </tbody>

            </table>

        </div>

    </div>

</div>

</body>
</html>



<select name="course">
                        {% for value,label in status_choice %}
                        <option value="{{value}}">
                            {{label}}
                        </option>
                        {% endfor %}
                    </select>